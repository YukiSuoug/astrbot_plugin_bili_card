# ==========================================
# 1. 忽略 Python 运行时产生的缓存垃圾文件
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ==========================================
# 2. 忽略本地虚拟环境（千万不要把依赖包传上去）
# ==========================================
venv/
.venv/
env/
ENV/

# ==========================================
# 3. 忽略各种编辑器的本地配置文件
# ==========================================
.vscode/
.idea/
.cursor/
*.suo
*.workspace

# ==========================================
# 4. 忽略本地日志文件与临时数据库
# ==========================================
*.log
*.db
*.sqlite3
_temp_/

# ==========================================
# 5. ⚠️ 极其重要：忽略任何可能包含敏感信息的本地配置文件
# ==========================================
# 比如您本地测试时临时写了 Cookie 的本地配置、.env 环境变量文件
.env
config_local.json